#encoding utf-8
#
# CRYSTAL4
#
DEF CRYSTAL4 X 0 40 N N 1 F N
F0 "X" 0 150 60 H V C CNN
F1 "CRYSTAL4" 0 -150 60 H V C CNN
F2 "" 0 0 60 H V C CNN
F3 "" 0 0 60 H V C CNN
DRAW
P 2 0 1 16  -100 100  -100 -100 N
P 2 0 1 16  100 100  100 -100 N
P 5 0 1 12  -50 50  50 50  50 -50  -50 -50  -50 50 f
X 1 1 -300 0 200 R 40 40 1 1 P
X GND 2 300 -300 200 L 40 40 1 1 W N
X 3 3 300 0 200 L 40 40 1 1 P
X GND 4 300 -400 200 L 40 40 1 1 W N
ENDDRAW
ENDDEF
